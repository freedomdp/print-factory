{
    "meta": {
        "project": "Print Factory",
        "version": "1.0.0",
        "description": "Дизайн-система для промислової 3D ферми Print Factory. Темна тема з бірюзовим акцентом та градієнтами.",
        "references": [
            "Мобільний скриншот Print Factory (бірюзовий #15EDC9)",
            "fdm.farm (сині градієнти, анімації, таймлайн)"
        ]
    },
    "colors": {
        "primary": {
            "main": "#15EDC9",
            "light": "#4DF4DA",
            "dark": "#0BC9A8",
            "glow": "rgba(21, 237, 201, 0.4)"
        },
        "secondary": {
            "teal_bright": "#4DF4DA",
            "teal_deep": "#10B8A0",
            "teal_dark": "#0A8A75"
        },
        "background": {
            "body": "#080C16",
            "level1": "#0F1419",
            "level2": "#1A1F2E",
            "level3": "#252B3A"
        },
        "text": {
            "primary": "#FFFFFF",
            "secondary": "#B0B8C8",
            "muted": "#6B7280"
        },
        "border": {
            "default": "rgba(255, 255, 255, 0.1)",
            "hover": "rgba(21, 237, 201, 0.3)"
        },
        "success": "#10B981",
        "warning": "#F59E0B",
        "error": "#EF4444"
    },
    "gradients": {
        "primary": {
            "direction": "135deg",
            "stops": [
                "#15EDC9 0%",
                "#0BC9A8 100%"
            ],
            "description": "Основний градієнт: світлий бірюзовий → темний бірюзовий"
        },
        "intense": {
            "direction": "135deg",
            "stops": [
                "#4DF4DA 0%",
                "#15EDC9 100%"
            ],
            "description": "Інтенсивний градієнт: яскравий бірюзовий → основний бірюзовий (аналог синього fdm.farm)"
        },
        "text": {
            "direction": "135deg",
            "stops": [
                "#4DF4DA 0%",
                "#0BC9A8 100%"
            ],
            "description": "Градієнт для тексту: світлий → темний з високою контрастністю"
        },
        "silver": {
            "direction": "135deg",
            "stops": [
                "#ffffff 0%",
                "#B0B8C8 100%"
            ],
            "description": "Срібний градієнт для заголовків (White -> Text Secondary)"
        },
        "subtle": {
            "direction": "135deg",
            "stops": [
                "#15EDC9 0%",
                "#10B8A0 100%"
            ],
            "description": "М'який градієнт для фонових елементів"
        },
        "background_blob": {
            "type": "radial",
            "stops": [
                "rgba(21, 237, 201, 0.15) 0%",
                "transparent 70%"
            ]
        }
    },
    "typography": {
        "fontFamily": {
            "primary": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
            "display": "Space Grotesk, Inter, sans-serif"
        },
        "fontSize": {
            "xs": "0.75rem",
            "sm": "0.875rem",
            "base": "1rem",
            "lg": "1.125rem",
            "xl": "1.25rem",
            "2xl": "1.5rem",
            "3xl": "1.875rem",
            "4xl": "2.25rem",
            "5xl": "3rem",
            "6xl": "3.75rem"
        },
        "fontWeight": {
            "normal": 400,
            "medium": 500,
            "semibold": 600,
            "bold": 700
        },
        "lineHeight": {
            "tight": 1.25,
            "normal": 1.5,
            "relaxed": 1.75
        },
        "elements": {
            "h1": {
                "fontSize": "3.75rem",
                "lineHeight": "1.1",
                "fontWeight": 700,
                "fontFamily": "display"
            },
            "h2": {
                "fontSize": "3rem",
                "lineHeight": "1.2",
                "fontWeight": 700,
                "fontFamily": "display"
            },
            "h3": {
                "fontSize": "2.25rem",
                "lineHeight": "1.3",
                "fontWeight": 600,
                "fontFamily": "display"
            },
            "h4": {
                "fontSize": "1.5rem",
                "lineHeight": "1.4",
                "fontWeight": 600,
                "fontFamily": "primary"
            },
            "h5": {
                "fontSize": "1.25rem",
                "lineHeight": "1.4",
                "fontWeight": 600,
                "fontFamily": "primary"
            },
            "h6": {
                "fontSize": "1rem",
                "lineHeight": "1.5",
                "fontWeight": 600,
                "fontFamily": "primary",
                "textTransform": "uppercase",
                "letterSpacing": "0.05em"
            },
            "p": {
                "fontSize": "1rem",
                "lineHeight": "1.6",
                "fontWeight": 400,
                "fontFamily": "primary",
                "color": "secondary"
            },
            "span": {
                "fontSize": "inherit",
                "fontWeight": "inherit",
                "fontFamily": "inherit"
            },
            "small": {
                "fontSize": "0.875rem",
                "fontWeight": 400,
                "color": "muted"
            }
        }
    },
    "spacing": {
        "xs": "0.25rem",
        "sm": "0.5rem",
        "md": "1rem",
        "lg": "1.5rem",
        "xl": "2rem",
        "2xl": "3rem",
        "3xl": "4rem",
        "4xl": "6rem"
    },
    "borderRadius": {
        "sm": "0.25rem",
        "md": "0.5rem",
        "lg": "0.75rem",
        "xl": "1rem",
        "2xl": "1.5rem",
        "full": "9999px"
    },
    "shadows": {
        "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
        "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
        "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
        "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1)",
        "glow_primary": "0 0 20px rgba(21, 237, 201, 0.5), 0 0 40px rgba(21, 237, 201, 0.3)"
    },
    "components": {
        "button": {
            "primary": {
                "background": "#15EDC9",
                "color": "#080C16",
                "padding": "0.75rem 1.5rem",
                "borderRadius": "0.75rem",
                "fontWeight": 600,
                "boxShadow": "0 0 20px rgba(21, 237, 201, 0.5)",
                "hover": {
                    "background": "#4DF4DA",
                    "boxShadow": "0 0 30px rgba(21, 237, 201, 0.7)"
                }
            },
            "secondary": {
                "background": "transparent",
                "color": "#15EDC9",
                "border": "1px solid #15EDC9",
                "padding": "0.75rem 1.5rem",
                "borderRadius": "0.75rem",
                "fontWeight": 600,
                "hover": {
                    "background": "rgba(21, 237, 201, 0.1)",
                    "borderColor": "#4DF4DA"
                }
            },
            "ghost": {
                "background": "transparent",
                "color": "#B0B8C8",
                "padding": "0.75rem 1.5rem",
                "borderRadius": "0.75rem",
                "fontWeight": 500,
                "hover": {
                    "background": "rgba(255, 255, 255, 0.05)",
                    "color": "#FFFFFF"
                }
            }
        },
        "card": {
            "background": "#1A1F2E",
            "border": "1px solid rgba(255, 255, 255, 0.1)",
            "borderRadius": "1rem",
            "padding": "1.5rem",
            "boxShadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
            "hover": {
                "borderColor": "rgba(21, 237, 201, 0.3)",
                "transform": "translateY(-2px)"
            }
        },
        "input": {
            "background": "#0F1419",
            "border": "1px solid rgba(255, 255, 255, 0.1)",
            "borderRadius": "0.75rem",
            "padding": "0.75rem 1rem",
            "color": "#FFFFFF",
            "focus": {
                "borderColor": "#15EDC9",
                "boxShadow": "0 0 0 3px rgba(21, 237, 201, 0.1)"
            }
        },
        "badge": {
            "background": "#15EDC9",
            "color": "#080C16",
            "padding": "0.25rem 0.75rem",
            "borderRadius": "9999px",
            "fontSize": "0.75rem",
            "fontWeight": 600
        },
        "timeline_step": {
            "number": {
                "background": "linear-gradient(135deg, #4DF4DA 0%, #0BC9A8 100%)",
                "size": "3rem",
                "borderRadius": "50%",
                "color": "#080C16",
                "fontWeight": 700
            },
            "icon": {
                "color": "#15EDC9",
                "size": "1.5rem"
            },
            "line": {
                "background": "rgba(21, 237, 201, 0.2)",
                "height": "2px"
            }
        },
        "mobile_menu": {
            "background": "rgba(20, 20, 20, 0.95)",
            "width": "80%",
            "maxWidth": "320px",
            "padding": "1.5rem",
            "direction": "left",
            "animation": "cubic-bezier(0.16, 1, 0.3, 1)",
            "duration": "0.4s"
        },
        "dropdown": {
            "background": "#1A1F2E",
            "border": "1px solid rgba(255, 255, 255, 0.1)",
            "borderRadius": "0.75rem",
            "padding": "0.5rem",
            "boxShadow": "0 10px 40px rgba(0, 0, 0, 0.3)",
            "item": {
                "padding": "0.75rem 1rem",
                "borderRadius": "0.5rem",
                "hover": {
                    "background": "rgba(255, 255, 255, 0.05)",
                    "color": "#FFFFFF"
                }
            }
        }
    },
    "animations": {
        "fade_in": {
            "duration": "0.6s",
            "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
        },
        "slide_up": {
            "duration": "0.8s",
            "easing": "cubic-bezier(0.16, 1, 0.3, 1)",
            "distance": "30px"
        },
        "pulse": {
            "duration": "2s",
            "easing": "ease-in-out",
            "infinite": true
        },
        "glow": {
            "duration": "3s",
            "easing": "ease-in-out",
            "infinite": true
        }
    },
    "breakpoints": {
        "mobile": "320px",
        "tablet": "768px",
        "desktop": "1024px",
        "wide": "1440px"
    },
    "effects": {
        "glassmorphism": {
            "background": "rgba(26, 31, 46, 0.7)",
            "backdropFilter": "blur(10px)",
            "border": "1px solid rgba(255, 255, 255, 0.1)"
        },
        "grid_pattern": {
            "background": "linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px)",
            "backgroundSize": "50px 50px"
        }
    }
}